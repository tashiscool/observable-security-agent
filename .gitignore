*.egg-info/
.pytest_cache/

# Secrets and local env (never publish)
.env
.env.*
!.env.example
creds.json
creds.*.json
*.pem

__pycache__/
*.py[cod]
.Python
.venv/
venv/
output/*.json
output/*.md
output/*.csv
!output/.gitkeep
!output/demo_walkthrough.md
!output/demo_walkthrough_coalfire.md

# Local agent run output (regenerable; may contain machine-local paths)
output_agent_run/

# Agentic fixture + bounded loop (make all / run-agent)
output_agentic/

# Ad-hoc 20x package from agentic output (not the primary evidence/package/)
evidence/package_agentic/

# Generated FedRAMP 20x evidence packages (reproducible via build-20x-package)
evidence/package/

# Generated assessment-tracker scenarios (reproducible via import-assessment-tracker)
fixtures/scenario_from_tracker/

# Read-only inspiration clones (full upstream repos for design study only).
# scripts/validate_everything.py :: step_reference_reuse_audit verifies no
# runtime module imports from this directory. Excerpts that ARE intentionally
# tracked live under reference_samples/ instead.
reference/

# Demo bundle outputs (reproducible via scripts/package_demo_artifacts.py).
demo_artifacts.zip
demo_artifacts_manifest.json

# Local validation harness output (reproducible via scripts/validate_everything.py).
validation_run/

# Local mirror/sync logs (scripts/sync_public_github.sh)
sync_gh.log
sync_gh.exit

# --- Security Evidence Explorer (web/) -------------------------------------
# Never commit macOS filesystem mirrors (e.g. copied /Applications, /Library)
# or a full second copy of this repo under web/.
web/Applications/
web/Library/
web/System/
web/FedRAMP20xMCP/
web/.tracker_artifacts/

# Only intentional explorer assets live at web/ root; everything else is noise.
web/*
!web/sample-data/
!web/sample-data/**
!web/index.html
!web/app.js
!web/styles.css
!web/fedramp20x.js
!web/tracker.js
!web/README.md
