{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://observable-security-agent.local/schemas/scanner-finding.schema.json",
  "title": "ScannerFinding (import interchange)",
  "description": "Canonical scanner row produced by Prowler/OCSF/ElectricEye-style adapters; aligns with core.models.ScannerFinding.",
  "type": "object",
  "required": ["finding_id", "scanner_name", "severity", "title", "status", "evidence"],
  "properties": {
    "finding_id": { "type": "string", "minLength": 1 },
    "scanner_name": { "type": "string", "minLength": 1 },
    "asset_id": { "type": ["string", "null"] },
    "target_id": { "type": ["string", "null"] },
    "severity": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low", "info"]
    },
    "title": { "type": "string", "minLength": 1 },
    "cve_ids": { "type": "array", "items": { "type": "string" } },
    "plugin_id": { "type": ["string", "null"] },
    "first_seen": { "type": ["string", "null"] },
    "last_seen": { "type": ["string", "null"] },
    "status": {
      "type": "string",
      "enum": ["open", "closed", "accepted", "false_positive", "unknown"]
    },
    "evidence": { "type": "string", "minLength": 1 },
    "raw_ref": { "type": ["string", "null"] },
    "exploitation_review": { "type": "object" },
    "metadata": {
      "type": "object",
      "description": "Provider-specific provenance (e.g. prowler_check_id, ocsf_class_uid, import_extras)."
    }
  },
  "additionalProperties": false
}
