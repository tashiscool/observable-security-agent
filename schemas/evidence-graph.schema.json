{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://observable-security-agent.local/schemas/evidence-graph.schema.json",
  "title": "Evidence graph (v3)",
  "type": "object",
  "additionalProperties": true,
  "required": ["version", "nodes", "edges"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Graph schema version; current export uses 3.0"
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/edge" }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["type", "id", "data"],
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "cloud_account",
            "asset",
            "declared_inventory_record",
            "event",
            "scanner_target",
            "scanner_finding",
            "log_source",
            "alert_rule",
            "ticket",
            "poam_item",
            "control",
            "evaluation",
            "event_mtype",
            "network_exposure",
            "ksi",
            "evidence_artifact"
          ]
        },
        "id": { "type": "string", "minLength": 1 },
        "data": { "type": "object" }
      }
    },
    "edge": {
      "type": "object",
      "required": ["from", "to", "relationship"],
      "additionalProperties": true,
      "properties": {
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 },
        "relationship": {
          "type": "string",
          "enum": [
            "BELONGS_TO_ACCOUNT",
            "HAS_PUBLIC_EXPOSURE",
            "HAS_FINDING",
            "COVERED_BY_SCANNER_TARGET",
            "MISSING_SCANNER_TARGET",
            "EMITS_LOGS_TO",
            "MISSING_CENTRAL_LOGGING",
            "COVERED_BY_ALERT",
            "MISSING_ALERT",
            "LINKED_TO_TICKET",
            "MISSING_TICKET",
            "TRACKED_BY_POAM",
            "MAPS_TO_CONTROL",
            "MAPS_TO_KSI",
            "SUPPORTED_BY_EVIDENCE",
            "INVENTORY_DESCRIBES_ASSET",
            "EVENT_TARGETS_ASSET",
            "INSTANCE_OF_EVENT_TYPE"
          ]
        },
        "data": { "type": "object" }
      }
    }
  }
}
