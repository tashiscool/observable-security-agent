{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://observable-security-agent.local/schemas/fedramp20x-package.schema.json",
  "title": "FedRAMP 20x–style evidence package (nested bundle or top-level manifest)",
  "description": "Custom project schema for machine-readable assessment snapshots. This is not an official FedRAMP publication schema; it models FedRAMP 20x–style KSI validation, findings, POA&M, and reconciliation fields.",
  "oneOf": [
    { "$ref": "#/$defs/NestedEvidenceBundle" },
    { "$ref": "#/$defs/TopLevelFedramp20xPackage" }
  ],
  "$defs": {
    "NestedEvidenceBundle": {
      "type": "object",
      "required": [
        "schema_version",
        "package_metadata",
        "system_boundary",
        "authorization_scope",
        "evidence_source_registry",
        "ksi_catalog",
        "control_crosswalk",
        "ksi_validation_results",
        "findings",
        "poam_items",
        "evidence_links",
        "reconciliation_summary"
      ],
      "properties": {
        "schema_version": { "type": "string", "const": "1.0" },
        "package_metadata": {
          "type": "object",
          "required": ["generated_at", "generator_id", "assessment_output_uri"],
          "properties": {
            "generated_at": { "type": "string" },
            "generator_id": { "type": "string" },
            "assessment_output_uri": { "type": "string" },
            "system_id": { "type": "string" },
            "program_display_name": { "type": "string" },
            "config_bundle_uri": { "type": "string" },
            "mappings_bundle_uri": { "type": "string" },
            "ksi_catalog_version": {
              "type": "string",
              "description": "Version / revision of config/ksi-catalog.yaml content carried into this package."
            },
            "fedramp20x_style_package_schema": {
              "type": "object",
              "description": "Pointer to this FedRAMP 20x–style nested package JSON Schema (not a GSA official schema).",
              "properties": {
                "label": { "type": "string" },
                "schema_id_uri": { "type": "string" },
                "project_relative_path": { "type": "string" }
              },
              "additionalProperties": true
            },
            "package_integrity": {
              "type": "object",
              "description": "Relative paths to checksum manifest and evidence-link bundles under the evidence root.",
              "properties": {
                "checksums_manifest_relative_path": { "type": "string" },
                "evidence_links_bundle_relative_path": { "type": "string" }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "system_boundary": { "type": "object", "additionalProperties": true },
        "authorization_scope": { "type": "object", "additionalProperties": true },
        "evidence_source_registry": { "type": "object", "additionalProperties": true },
        "ksi_catalog": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "ksi_id",
              "theme",
              "title",
              "objective",
              "legacy_controls",
              "validation_mode",
              "automation_target",
              "pass_fail_criteria"
            ],
            "properties": {
              "ksi_id": { "type": "string" },
              "theme": { "type": "string" },
              "title": { "type": "string" },
              "objective": { "type": "string" },
              "legacy_controls": { "type": "object", "additionalProperties": true },
              "validation_mode": {
                "type": "string",
                "enum": ["automated", "manual", "hybrid"]
              },
              "automation_target": { "type": "boolean" },
              "evidence_sources": { "type": "array", "items": { "type": "string" } },
              "pass_fail_criteria": {
                "type": "array",
                "items": { "type": "object", "additionalProperties": true }
              },
              "reporting_sections": { "type": "object", "additionalProperties": true }
            },
            "additionalProperties": true
          }
        },
        "control_crosswalk": {
          "type": "object",
          "required": ["rev4_to_rev5", "rev5_to_20x_ksi"],
          "properties": {
            "rev4_to_rev5": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["rev4_control_id", "rev5_control_id"],
                "properties": {
                  "rev4_control_id": { "type": "string" },
                  "rev5_control_id": { "type": "string" },
                  "notes": { "type": "string" }
                },
                "additionalProperties": true
              }
            },
            "rev5_to_20x_ksi": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["rev5_control_id", "ksi_id", "mapping_type"],
                "properties": {
                  "rev5_control_id": { "type": "string" },
                  "ksi_id": { "type": "string" },
                  "mapping_type": { "type": "string" }
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        },
        "ksi_validation_results": {
          "type": "array",
          "items": {
            "$ref": "https://observable-security-agent.local/schemas/ksi-result.schema.json"
          }
        },
        "findings": {
          "type": "array",
          "items": {
            "$ref": "https://observable-security-agent.local/schemas/finding.schema.json"
          }
        },
        "poam_items": {
          "type": "array",
          "items": {
            "$ref": "https://observable-security-agent.local/schemas/poam-item.schema.json"
          }
        },
        "evidence_links": {
          "type": "array",
          "items": {
            "$ref": "https://observable-security-agent.local/schemas/evidence-link.schema.json"
          }
        },
        "reconciliation_summary": {
          "$ref": "https://observable-security-agent.local/schemas/reconciliation.schema.json"
        },
        "assessment_correlation_snapshot": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "TopLevelFedramp20xPackage": {
      "type": "object",
      "required": [
        "package_id",
        "package_version",
        "generated_at",
        "system",
        "scope",
        "summary",
        "schema",
        "artifacts",
        "integrity"
      ],
      "properties": {
        "package_id": { "type": "string", "minLength": 1 },
        "package_version": { "type": "string", "minLength": 1 },
        "generated_at": { "type": "string", "minLength": 1 },
        "system": {
          "type": "object",
          "required": [
            "id",
            "name",
            "impact_level",
            "authorization_path",
            "cloud_provider",
            "regions"
          ],
          "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "impact_level": { "type": "string" },
            "authorization_path": { "type": "string" },
            "cloud_provider": { "type": "string" },
            "regions": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": true
        },
        "scope": {
          "type": "object",
          "required": [
            "included_components",
            "excluded_components",
            "minimum_assessment_scope_applied"
          ],
          "properties": {
            "included_components": {
              "type": "array",
              "items": { "type": "string" }
            },
            "excluded_components": {
              "type": "array",
              "items": { "type": "string" }
            },
            "minimum_assessment_scope_applied": { "type": "boolean" }
          },
          "additionalProperties": true
        },
        "summary": {
          "type": "object",
          "required": [
            "total_ksis",
            "ksis_addressed",
            "automated_ksis",
            "manual_or_hybrid_ksis",
            "automation_percentage",
            "passed",
            "failed",
            "partial",
            "not_applicable",
            "open_poam_items",
            "critical_open_findings",
            "high_open_findings"
          ],
          "properties": {
            "total_ksis": { "type": "integer", "minimum": 0 },
            "ksis_addressed": { "type": "integer", "minimum": 0 },
            "automated_ksis": { "type": "integer", "minimum": 0 },
            "manual_or_hybrid_ksis": { "type": "integer", "minimum": 0 },
            "automation_percentage": { "type": "number" },
            "passed": { "type": "integer", "minimum": 0 },
            "failed": { "type": "integer", "minimum": 0 },
            "partial": { "type": "integer", "minimum": 0 },
            "not_applicable": { "type": "integer", "minimum": 0 },
            "open_poam_items": { "type": "integer", "minimum": 0 },
            "critical_open_findings": { "type": "integer", "minimum": 0 },
            "high_open_findings": { "type": "integer", "minimum": 0 },
            "catalog_automation_target_ksis": { "type": "integer", "minimum": 0 },
            "catalog_automation_percentage": { "type": "number" }
          },
          "additionalProperties": true
        },
        "schema": {
          "type": "object",
          "required": ["name", "version", "uri"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 },
            "uri": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": true
        },
        "artifacts": {
          "type": "object",
          "required": [
            "ksi_results",
            "findings",
            "poam_items",
            "evidence_links",
            "reconciliation",
            "assessor_report",
            "executive_report",
            "ao_report",
            "reconciliation_report"
          ],
          "properties": {
            "ksi_results": { "type": "string", "minLength": 1 },
            "findings": { "type": "string", "minLength": 1 },
            "poam_items": { "type": "string", "minLength": 1 },
            "evidence_links": { "type": "string", "minLength": 1 },
            "reconciliation": { "type": "string", "minLength": 1 },
            "assessor_report": { "type": ["string", "null"] },
            "executive_report": { "type": ["string", "null"] },
            "ao_report": { "type": ["string", "null"] },
            "reconciliation_report": { "type": ["string", "null"] }
          },
          "additionalProperties": true
        },
        "integrity": {
          "type": "object",
          "required": ["checksums_file", "signed"],
          "properties": {
            "checksums_file": { "type": "string", "minLength": 1 },
            "signed": { "type": "boolean" },
            "signature_file": { "type": ["string", "null"] }
          },
          "additionalProperties": true
        },
        "embedded": {
          "type": "object",
          "properties": {
            "evidence_source_registry": { "type": "object", "additionalProperties": true },
            "eval_correlation_id": { "type": ["string", "null"] }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    }
  }
}
