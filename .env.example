# AWS (optional — used by collect_aws_evidence.py / AWS evidence exports)
AWS_REGION=us-east-1
AWS_PROFILE=default

# Optional default evidence directory for scripts/run_aws_assessment.py
# AWS_EVIDENCE_DIR=./exports/aws-latest

# AI / LLM reasoning (all OPTIONAL).
#
# When AI_API_KEY is unset, every reasoner in `ai.reasoning` falls back to a
# deterministic template derived from the supplied artifacts. All tests pass
# without these set; the LLM is used ONLY for use cases where deterministic
# logic underdetermines the answer (ambiguous tracker rows, audience-targeted
# explanations, draft text). Pass/fail computation, schema validation, and
# evidence existence are NEVER routed through the LLM.
#
# AI_API_BASE   default: https://api.openai.com/v1
# AI_MODEL      default: gpt-4o-mini
# AI_API_KEY    no default — leave unset to force deterministic fallback.
#
# AI_API_BASE=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini
# AI_API_KEY=

